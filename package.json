{
  "name": "quran-school-manager",
  "version": "1.0.0",
  "description": "نظام إدارة المدرسة القرآنية",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.quran.school",
    "productName": "نظام المدرسة القرآنية",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "package.json",
      "icon.ico",
      "node_modules/**",
      "!node_modules/*/{CHANGELOG.md,README.md,readme.md}",
      "!node_modules/*/{test,__tests__,tests,example,examples}",
      "!node_modules/**/*.map",
      "!node_modules/**/*.md"
    ],
    "win": {
      "target": {
        "target": "nsis",
        "arch": ["x64"]
      },
      "icon": "icon.ico",
      "compression": "maximum"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "المدرسة القرآنية",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "license": null
    }
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
